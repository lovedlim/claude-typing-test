rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /scores/{document} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['nickname', 'wpm', 'accuracy', 'grade'])
                    && (request.resource.data.wpm is int || request.resource.data.wpm is float)
                    && request.resource.data.wpm >= 0
                    && request.resource.data.wpm <= 300;
    }
  }
}
